# Copy to backend/.env for direct uvicorn and Alembic execution.
# Change DATABASE_URL to the real PostgreSQL user, password, host and database.
APP_ENV=development
SECRET_KEY=change-this-secret-key-for-local-development
ACCESS_TOKEN_EXPIRE_MINUTES=60
DATABASE_URL=postgresql+psycopg://genforge:genforge@localhost:5432/genforge
REDIS_URL=redis://localhost:6379/0
STORAGE_DIR=storage_data/uploads
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://200.235.143.10:5173
