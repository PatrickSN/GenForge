# Shared safe example for Docker Compose and local development.
# Copy to .env and change SECRET_KEY and database credentials before server testing.
APP_ENV=development
SECRET_KEY=change-this-secret-key-for-local-development
ACCESS_TOKEN_EXPIRE_MINUTES=60
DATABASE_URL=postgresql+psycopg://genforge:genforge@postgres:5432/genforge
REDIS_URL=redis://redis:6379/0
STORAGE_DIR=/data/genforge/uploads
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://200.235.143.10:5173
POSTGRES_DB=genforge
POSTGRES_USER=genforge
POSTGRES_PASSWORD=genforge
VITE_API_BASE_URL=http://localhost:8000
